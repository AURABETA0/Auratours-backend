# ═══════════════════════════════════════════════════════════
#  AURA ROME TOURS — Variabili d'ambiente
#  Rinomina questo file in ".env" e inserisci i tuoi valori
#  NON caricare mai il file .env su GitHub!
# ═══════════════════════════════════════════════════════════

# ── STRIPE ──────────────────────────────────────────────────
# Vai su: dashboard.stripe.com → Developers → API Keys
# In TEST usa sk_test_... / in PRODUZIONE usa sk_live_...
STRIPE_SECRET_KEY=sk_test_INSERISCI_QUI

# ── ANTHROPIC (Claude AI) ───────────────────────────────────
# Vai su: console.anthropic.com → API Keys → Create Key
ANTHROPIC_API_KEY=sk-ant-INSERISCI_QUI

# ── EMAIL ───────────────────────────────────────────────────
# L'email da cui partono le notifiche (es. info@aurarometours.com)
# Se usi Gmail: vai su myaccount.google.com → Sicurezza → App Password
# Se usi Aruba: usa i dati SMTP del pannello Aruba
EMAIL_USER=info@aurarometours.com
EMAIL_PASS=INSERISCI_APP_PASSWORD

# L'email che riceve le notifiche di nuove prenotazioni
EMAIL_NOTIFY=tua-email-personale@gmail.com

# ── SERVER ──────────────────────────────────────────────────
# Railway lo imposta automaticamente, non toccare
PORT=3000
